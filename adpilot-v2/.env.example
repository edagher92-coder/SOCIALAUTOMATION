# AdPilot OS V2 — environment variables. Copy to .env.local and fill in.
# NEVER commit real values. .env.local is git-ignored.

# --- Supabase (auth + Postgres + RLS) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY   # server-only, never exposed to the browser

# --- Stripe (billing) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PRICE_STARTER=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_EXPERT=price_xxx   # top tier: white-label + expert plugins

# --- Meta / TikTok Ads (read-only first; V2 'should-ship') ---
META_APP_ID=
META_APP_SECRET=
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
OAUTH_REDIRECT_BASE=http://localhost:3000

# --- Content Studio publishing (WRITE scopes — organic posts/reels only; separate from ads) ---
# Leave blank to keep publishing disabled (composing/scheduling still works; publish reports "not configured").
META_PAGE_ACCESS_TOKEN=     # Page token: pages_manage_posts / instagram_content_publish (publishing) + pages_messaging / pages_manage_metadata (Messenger setup)
META_PAGE_ID=               # Facebook Page id (for FB posts)
IG_USER_ID=                 # Instagram Business account id (for IG posts/reels)
TIKTOK_PUBLISH_TOKEN=       # TikTok Content Posting API token (audited app for public posts)

# --- Email (Resend) — weekly digests & alerts ---
RESEND_API_KEY=
EMAIL_FROM=AdPilot OS <onboarding@resend.dev>
CRON_SECRET=                # protects /api/cron/weekly-digest (Vercel Cron Bearer)

# --- Token encryption (OAuth tokens at rest) ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=

# --- AI generation (server-side; powers Canva Creator / Bobby / Aria) ---
ANTHROPIC_API_KEY=          # sk-ant-... (server only; never NEXT_PUBLIC)
ANTHROPIC_MODEL=claude-sonnet-4-6   # or claude-opus-4-8 for deepest output

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
SUPPORT_EMAIL=            # shown in the manual / error-reporting; set your real support address
INGEST_API_KEY=           # optional: lets MCP/automation push data to /api/ingest with x-api-key
