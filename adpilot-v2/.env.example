# AdPilot OS V2 — environment variables. Copy to .env.local and fill in.
# NEVER commit real values. .env.local is git-ignored.

# --- Supabase (auth + Postgres + RLS) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY   # server-only, never exposed to the browser

# --- Stripe (billing) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PRICE_STARTER=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_EXPERT=price_xxx   # top tier: white-label + expert plugins

# --- Meta / TikTok Ads (read-only first; V2 'should-ship') ---
META_APP_ID=
META_APP_SECRET=
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
OAUTH_REDIRECT_BASE=http://localhost:3000
META_GRAPH_API_VERSION=v21.0   # single source for the Graph API version — bump when Meta increments

# --- Content Studio publishing (WRITE scopes — organic posts/reels only; separate from ads) ---
# Leave blank to keep publishing disabled (composing/scheduling still works; publish reports "not configured").
META_PAGE_ACCESS_TOKEN=     # Page token: pages_manage_posts / instagram_content_publish (publishing) + pages_messaging / pages_manage_metadata (Messenger setup)
META_PAGE_ID=               # Facebook Page id (for FB posts)
IG_USER_ID=                 # Instagram Business account id (for IG posts/reels)
TIKTOK_PUBLISH_TOKEN=       # TikTok Content Posting API token (audited app for public posts)
MESSENGER_VERIFY_TOKEN=     # any random string — Meta webhook verification (Messenger bot); META_APP_SECRET (above) signs webhook payloads

# --- Live organic-insights sync (scaffold; OFF by default) ---
# Reuses META_PAGE_ACCESS_TOKEN above, but needs READ scopes: pages_read_engagement (Page) and
# instagram_manage_insights (IG). The daily /api/cron/organic-sync pulls organic post reach into
# the Boost & Reach analysis. INERT until ORGANIC_SYNC_ORG_ID is set (+ a Page/IG id). Read-only.
ORGANIC_SYNC_ORG_ID=        # the org id to attribute synced organic posts to (single-tenant for now)

# --- Guarded ad-write Actions (Expert; OFF by default) ---
# Master kill-switch for LIVE ad changes (pause/resume/budget). Leave UNSET to keep the
# product strictly read-only; set to 1 ONLY after connecting an ads_management write-scope
# account (needs Meta App Review). Even when on, every action needs a typed-YES confirmation.
ADS_WRITE_ENABLED=

# --- Email (Resend) — weekly digests & alerts ---
RESEND_API_KEY=
EMAIL_FROM=AdPilot OS <onboarding@resend.dev>
CRON_SECRET=                # protects ALL crons (auto-sync, publish, auto-analysis, weekly-digest, refresh-knowledge); Vercel Cron Bearer

# --- Token encryption (OAuth tokens at rest) ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=

# --- Lead/CRM webhook (v4) — inbound lead-quality loop ---
CRM_WEBHOOK_SECRET=          # HMAC-SHA256 secret; inbound /api/webhooks/crm fails closed (403) if unset
PII_PEPPER=                  # REQUIRED in prod: salt for one-way SHA-256 hashing of lead email/phone (no plaintext stored)

# --- Private business context pack (v4; optional) ---
# Leave UNSET for the clean, resale-safe build. Set to a JSON pack {"id","shared","agents":{...}}
# to ground the AI specialists in one business's private context at runtime (never committed).
ADPILOT_CONTEXT_PACK_JSON=

# --- AI generation (server-side; powers Canva Creator / Bobby / Aria) ---
ANTHROPIC_API_KEY=          # sk-ant-... (server only; never NEXT_PUBLIC)
ANTHROPIC_MODEL=claude-sonnet-4-6   # or claude-opus-4-8 for deepest output

# --- Adobe Firefly Services (Creative Studio image generation; Pro & Expert) ---
# Server-to-server credentials from the Adobe Developer Console (Firefly Services). With these set,
# the Creative Studio can generate ad creative images. Leave blank to keep generation disabled
# (the route reports NOT_CONFIGURED). Never expose these to the browser.
FIREFLY_CLIENT_ID=          # x-api-key / IMS client id
FIREFLY_CLIENT_SECRET=      # IMS client secret (used to mint a client_credentials token)
# FIREFLY_ACCESS_TOKEN=     # optional: a short-lived token to test without client_credentials
# FIREFLY_SCOPES=openid,AdobeID,firefly_api,ff_apis   # override default IMS scopes if needed

# --- Google Gemini / Imagen (Creative Studio image generation; Pro & Expert) ---
# Direct Google AI Studio API key. Default creative engine when set (returns self-contained images).
GEMINI_API_KEY=             # AI Studio API key (server only; never NEXT_PUBLIC)
# GEMINI_IMAGE_MODEL=imagen-4.0-fast-generate-001   # override the text→image (Imagen) model
# GEMINI_EDIT_MODEL=gemini-2.5-flash-image          # override the image→image (edit/vary) model

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
SUPPORT_EMAIL=            # shown in the manual / error-reporting; set your real support address
INGEST_API_KEY=           # optional: lets MCP/automation push data to /api/ingest with x-api-key

# --- Report delivery (Google Drive + Gmail; scaffold, OFF by default) ---
# Server-generated report PDFs are LIVE (the "Download PDF" button on any report). Auto-delivery
# to Drive/Gmail is INERT until a Google service account is configured (owner-gated — needs a
# service account with Drive/Gmail scopes; Gmail also needs domain-wide delegation). Read-only.
GOOGLE_DELIVERY_CLIENT_EMAIL=   # service-account email
GOOGLE_DELIVERY_PRIVATE_KEY=    # service-account private key (PEM; escape newlines as \n)
GOOGLE_DRIVE_FOLDER_ID=         # target Drive folder id for uploaded report PDFs
GOOGLE_GMAIL_FROM=              # sender address for emailed reports (domain-wide delegation)
