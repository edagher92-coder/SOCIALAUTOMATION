{
  "name": "adpilot-os",
  "version": "7.0.0",
  "private": true,
  "description": "AdPilot OS V7 — explainable Meta and TikTok operations with guarded automation.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "seed:demo:dry": "tsx scripts/seed-demo.ts --dry-run",
    "seed:demo:clean": "tsx scripts/seed-demo.ts --clean"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.4",
    "next": "^16.2.11",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "stripe": "^16.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.11",
    "postcss": "8.5.21",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.2",
    "typescript": "^5.6.2",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "next": {
      "postcss": "$postcss",
      "sharp": "0.35.3"
